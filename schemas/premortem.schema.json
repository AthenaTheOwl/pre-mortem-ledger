{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vigneshthegreat/pre-mortem-ledger/schemas/premortem.schema.json",
  "title": "PreMortem",
  "description": "One monthly pre-mortem for one position. Persisted as YAML front-matter at the top of a Markdown file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["position", "month", "failure_modes"],
  "properties": {
    "position": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]{0,7}$",
      "description": "Uppercase ticker symbol or placeholder (1-8 chars)."
    },
    "month": {
      "type": "string",
      "pattern": "^[0-9]{4}-M(0[1-9]|1[0-2])$",
      "description": "Pre-mortem month in YYYY-Mnn form, e.g. 2026-M07."
    },
    "exposure_tier": {
      "type": "string",
      "enum": ["concentrated", "sized", "probe"],
      "default": "concentrated"
    },
    "failure_modes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "narrative",
          "rank",
          "rubric_category",
          "observability_triggers",
          "status_log"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^fm-[0-9]{1,3}$" },
          "title": { "type": "string", "minLength": 4 },
          "narrative": { "type": "string", "minLength": 20 },
          "rank": { "type": "integer", "minimum": 1, "maximum": 10 },
          "rubric_category": { "type": "string" },
          "observability_triggers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "status_log": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["month", "status"],
              "properties": {
                "month": {
                  "type": "string",
                  "pattern": "^[0-9]{4}-M(0[1-9]|1[0-2])$"
                },
                "status": {
                  "type": "string",
                  "enum": ["unchanged", "evidence-emerging", "observed", "retired"]
                },
                "evidence_ref": { "type": ["string", "null"] },
                "note": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    }
  }
}
